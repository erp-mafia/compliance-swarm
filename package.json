{
  "name": "compliance-swarm-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-framework compliance orchestrator (OSS-license, OWASP ASVS, ISO 27001, SOC 2, GDPR)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/erp-mafia/compliance-swarm.git"
  },
  "homepage": "https://github.com/erp-mafia/compliance-swarm#readme",
  "bugs": "https://github.com/erp-mafia/compliance-swarm/issues",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm --workspaces --if-present run build",
    "test": "npm --workspaces --if-present run test",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "lint": "npm --workspaces --if-present run lint",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
